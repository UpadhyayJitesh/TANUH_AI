<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/title_voice_memo"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/subtitle_voice_memo"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#E8F0FE"
            android:padding="16dp"
            android:text="@string/models_not_ready"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2" />

        <CheckBox
            android:id="@+id/meteredCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/allow_metered" />

        <Button
            android:id="@+id/prepareButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/prepare_models" />

        <Button
            android:id="@+id/recordButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:text="@string/record_memo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/transcript_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/transcriptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#F5F5F5"
            android:minHeight="96dp"
            android:padding="16dp"
            android:text="@string/no_memo_yet" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/classification_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/classificationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#F5F5F5"
            android:minHeight="72dp"
            android:padding="16dp"
            android:text="@string/waiting_for_transcript" />

        <Button
            android:id="@+id/modelInfoButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:drawableStart="@drawable/ic_info_outline"
            android:drawablePadding="8dp"
            android:text="@string/show_model_info" />

        <TextView
            android:id="@+id/modelInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#E8F0FE"
            android:lineSpacingExtra="2dp"
            android:padding="16dp"
            android:text="@string/model_info_unavailable"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
